# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Generated logs and caches
logs/*.log
__pycache__/
*.pyc
*.tar.gz

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
# /out/ — kept in git so CI can deploy pre-built static output without rebuilding

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
